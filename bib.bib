@techreport{fong2021conformal,
  abstract = {We develop scalable methods for producing conformal Bayesian predictive intervals with finite sample calibration guarantees. Bayesian posterior predictive distributions, \textbackslash \textdollar p(y {\textbackslash textbackslash}mid x)\textbackslash \textdollar , characterize subjective beliefs on outcomes of interest, \textbackslash \textdollar y\textbackslash \textdollar , conditional on predictors, \textbackslash \textdollar x\textbackslash \textdollar . Bayesian prediction is well-calibrated when the model is true, but the predictive intervals may exhibit poor empirical coverage when the model is misspecified, under the so called \textbackslash \textdollar \textbackslash {{\textbackslash textbackslash}cal\textbackslash {M\textbackslash }\textbackslash }\textbackslash \textdollar -open perspective. In contrast, conformal inference provides finite sample frequentist guarantees on predictive confidence intervals without the requirement of model fidelity. Using \textquotesingle add-one-in\textquotesingle  importance sampling, we show that conformal Bayesian predictive intervals are efficiently obtained from re-weighted posterior samples of model parameters. Our approach contrasts with existing conformal methods that require expensive refitting of models or data-splitting to achieve computational efficiency. We demonstrate the utility on a range of examples including extensions to partially exchangeable settings such as hierarchical models.},
  annotation = {Comment: 19 pages, 4 figures, 12 tables; added references and fixed typos},
  author = {Fong, Edwin and Holmes, Chris},
  date = {2021-06},
  doi = {10.48550/arXiv.2106.06137},
  institution = {arXiv},
  keywords = {Statistics - Methodology, Statistics - Computation},
  note = {arXiv:2106.06137 [stat] type: article},
  title = {Conformal Bayesian Computation},
  url = {http://arxiv.org/abs/2106.06137},
  urldate = {2023-07-19},
}

