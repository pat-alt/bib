@inproceedings{xu2021conformal,
  abstract = {We develop a method to construct distribution-free prediction intervals for dynamic time-series, called {\textbackslash textbackslash}Verb{\textbackslash textbar}EnbPI{\textbackslash textbar} that wraps around any bootstrap ensemble estimator to construct sequential prediction intervals. {\textbackslash textbackslash}Verb{\textbackslash textbar}EnbPI{\textbackslash textbar} is closely related to the conformal prediction (CP) framework but does not require data exchangeability. Theoretically, these intervals attain finite-sample, {\textbackslash textbackslash}textit\textbackslash {approximately valid\textbackslash } marginal coverage for broad classes of regression functions and time-series with strongly mixing stochastic errors. Computationally, {\textbackslash textbackslash}Verb{\textbackslash textbar}EnbPI{\textbackslash textbar} avoids overfitting and requires neither data-splitting nor training multiple ensemble estimators; it efficiently aggregates bootstrap estimators that have been trained. In general, {\textbackslash textbackslash}Verb{\textbackslash textbar}EnbPI{\textbackslash textbar} is easy to implement, scalable to producing arbitrarily many prediction intervals sequentially, and well-suited to a wide range of regression functions. We perform extensive real-data analyses to demonstrate its effectiveness.},
  author = {Xu, Chen and Xie, Yao},
